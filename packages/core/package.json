  "bugs": {
    "url": "https://github.com/Noa-Lia/codetitan.dev/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "simple-git": "^3.35.3"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    },
    "sqlite3": {
      "optional": true
    }
  },
